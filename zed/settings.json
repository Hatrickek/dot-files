// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_ui_font_size": 16.0,
  "ui_font_weight": 100.0,
  "ui_font_family": ".ZedSans",
  "cli_default_open_behavior": "existing_window",
  "format_on_save": "off",
  "mouse_wheel_zoom": true,
  "buffer_line_height": {
    "custom": 1.399999976158142,
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "confirm_quit": true,
  "disable_ai": true,
  "agent": {
    "dock": "right",
    "model_parameters": [],
    "enable_feedback": false,
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "vim_mode": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vertical_scroll_margin": 5.0,
  "minimap": {
    "show": "never",
  },
  "cursor_blink": true,
  "buffer_font_family": ".ZedMono",
  "file_types": {},
  "show_whitespaces": "trailing",
  "show_edit_predictions": true,
  "indent_guides": {
    "enabled": false,
  },
  "tab_size": 2,
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 18.0,
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light Hard",
    "dark": "Gruvbox Dark Hard",
  },
  "lsp": {
    "clangd": {
      "binary": {
        "arguments": [
          "--query-driver=C:\\Program Files\\LLVM\\bin\\clang-cl.exe",
          "--header-insertion=never",
        ],
      },
    },
    "lua-language-server": {
      "settings": {
        "Lua": {
          "diagnostics": {
            "disable": ["undefined-global", "lowercase-global"],
          },
        },
      },
    },
  },

  "theme_overrides": {
    "Gruvbox Dark Hard": {
      "accents": [
        "#cc241dff",
        "#98971aff",
        "#d79921ff",
        "#458588ff",
        "#b16286ff",
        "#689d6aff",
        "#d65d0eff",
      ],
      "elevated_surface.background": "#171717FF",
      "surface.background": "#171717FF",
      "background": "#171717FF",
      "status_bar.background": "#171717FF",
      "title_bar.background": "#171717FF",
      "toolbar.background": "#0D0D0DD7",
      "tab_bar.background": "#171717FF",
      "tab.inactive_background": "#171717FF",
      "tab.active_background": "#0D0D0DD7",
      "panel.background": "#171717FF",
      "editor.background": "#0D0D0DD7",
      "editor.gutter.background": "#1D2021FF",
      "editor.subheader.background": "#171717FF",
      "editor.highlighted_line.background": "#171717FF",
      "terminal.background": "#0D0D0DD7",
      "players": [
        {
          "cursor": "#FFBF00FF",
          "background": "#83a598ff",
          "selection": "#83a5983d",
        },
      ],
      "panel.overlay_background": "#171717FF",
      "panel.overlay_hover": "#171717FF",
    },
  },
}
