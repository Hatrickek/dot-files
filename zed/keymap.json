[
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-w": "pane::CloseActiveItem",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-w": "pane::CloseActiveItem",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {},
  },
  {
    "context": "Editor && vim_mode == visual && !VimWaiting && !VimObject",
    "bindings": {
      "p": ["vim::Paste", { "preserve_clipboard": true }],
    },
  },
]

